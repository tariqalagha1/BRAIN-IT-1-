# Brain it Core API - Environment Configuration
# Copy this file to .env and update values

# Core Application
APP_NAME=Brain it Core API
APP_ENV=development|production
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Database Configuration
# Development: use SQLite
# Production: use PostgreSQL (postgresql://user:password@host:port/dbname)
DATABASE_URL=sqlite:///./clinicalmind.db

# API Authentication
API_KEY_REQUIRED=false
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
API_LOG_LEVEL=INFO

# Admin Emails (comma-separated)
ADMIN_EMAILS=admin@clinicalmind.app
