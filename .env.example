# ============================================
# Brain it Platform - Environment Configuration
# ============================================
# Copy this file to .env and update values

# Core Application
APP_NAME=Brain it Platform
APP_ENV=development|production
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Database Configuration
DB_USER=brainit_user
DB_PASSWORD=brainit_password
DB_NAME=brainit_db
DATABASE_URL=postgresql://brainit_user:brainit_password@postgres:5432/brainit_db

# API Authentication
API_KEY_REQUIRED=true
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Origins (comma-separated)
# Include all frontend domains that should access the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Agent Service URLs
# Use docker service names when running in Docker
# Use localhost when running locally
ECHO_AGENT_URL=http://echo-agent:8001
TRANSFORM_AGENT_URL=http://transform-agent:8002

# Logging Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
API_LOG_LEVEL=INFO
AGENT_LOG_LEVEL=INFO

# Frontend Configuration
# The API URL that the frontend will use to connect to the backend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=production

# Optional Service Names
ECHO_AGENT_NAME=Echo Agent Service
TRANSFORM_AGENT_NAME=Transform Agent Service
