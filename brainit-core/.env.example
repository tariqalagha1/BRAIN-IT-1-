# Brain it Orchestration Core - Environment Configuration
# Copy this file to .env and update values

# Core Application
APP_NAME=Brain it Orchestration Core
APP_ENV=development|production
LOG_LEVEL=DEBUG|INFO|WARNING|ERROR

# Database Configuration
# Development: use SQLite
# Production: use PostgreSQL (postgresql://user:password@host:port/dbname)
DATABASE_URL=sqlite:///./brainit_core.db

# Agent Service URLs (used for orchestration)
# Development: http://localhost:PORT
# Docker: http://service_name:PORT
ECHO_AGENT_URL=http://localhost:8001
TRANSFORM_AGENT_URL=http://localhost:8002

